APP_NAME=Ansiversa API
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
PARENT_DATABASE_URL=sqlite:///./ansiversa_api.db
JWT_SECRET_KEY=change-this-local-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ANSIVERSA_AUTH_SECRET=dev-ansiversa-auth-secret
CORS_ORIGINS=http://localhost:4321,https://ansiversa.com,https://www.ansiversa.com
