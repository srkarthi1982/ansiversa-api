APP_NAME=Ansiversa API
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
PARENT_DATABASE_URL=sqlite:///./ansiversa_api.db
TURSO_AUTH_TOKEN=
QUIZ_DATABASE_URL=sqlite:///./quiz.db
LANGUAGE_FLASHCARDS_DATABASE_URL=sqlite:///./language_flashcards.db
EXAM_DATABASE_URL=sqlite:///./exam.db
LESSON_BUILDER_DATABASE_URL=sqlite:///./lesson_builder.db
MEMORY_TRAINER_DATABASE_URL=sqlite:///./memory_trainer.db
AI_NOTES_SUMMARIZER_DATABASE_URL=sqlite:///./ai_notes_summarizer.db
STUDY_PLANNER_DATABASE_URL=sqlite:///./study_planner.db
COURSE_TRACKER_DATABASE_URL=sqlite:///./course_tracker.db
SMART_TEXTBOOK_SCANNER_DATABASE_URL=sqlite:///./smart_textbook_scanner.db
RESUME_BUILDER_DATABASE_URL=sqlite:///./resume_builder.db
VISITING_CARD_MAKER_DATABASE_URL=sqlite:///./visiting_card_maker.db
INTERVIEW_COACH_DATABASE_URL=sqlite:///./interview_coach.db
AI_JOB_INTERVIEWER_DATABASE_URL=sqlite:///./ai_job_interviewer.db
QUIZ_ATTEMPT_EXPIRE_HOURS=2
JWT_SECRET_KEY=change-this-local-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
ANSIVERSA_AUTH_SECRET=dev-ansiversa-auth-secret
AUTH_COOKIE_NAME=ansiversa_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_SECONDS=1800
CORS_ORIGINS=http://localhost:4321,http://localhost:5173,https://ansiversa.com,https://www.ansiversa.com
